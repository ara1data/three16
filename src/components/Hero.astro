---

---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden px-6">
  <!-- Gradient orb background -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute left-1/2 top-1/3 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent/[0.03] blur-[120px]"></div>
    <div class="absolute bottom-0 left-1/2 h-px w-[600px] max-w-full -translate-x-1/2 bg-gradient-to-r from-transparent via-border to-transparent"></div>
  </div>

  <div class="reveal relative mx-auto max-w-[800px] text-center">
    <p class="mb-6 font-mono text-xs font-medium tracking-[0.2em] text-text-muted uppercase">
      Independent AI Products Studio
    </p>
    <h1 class="font-heading text-5xl font-bold leading-[1.1] tracking-tight sm:text-6xl md:text-7xl lg:text-8xl">
      <span class="gradient-text">We build what's</span>
      <br />
      <span class="text-accent">next.</span>
    </h1>
    <p class="mx-auto mt-8 max-w-[520px] text-base leading-relaxed text-text-secondary sm:text-lg">
      Focused, useful AI products — from live consumer tools to agentic systems taking shape in the lab.
    </p>
    <div class="mt-12 flex items-center justify-center gap-6">
      <a
        href="#products"
        class="group inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/10 px-6 py-3 text-sm font-medium text-accent transition-all duration-300 hover:border-accent/40 hover:bg-accent/15 hover:shadow-[0_0_30px_-6px_rgba(110,231,183,0.2)]"
      >
        See what we're building
        <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2">
    <p class="font-mono text-[10px] uppercase tracking-[0.25em] text-text-muted">Scroll</p>
  </div>
</section>
