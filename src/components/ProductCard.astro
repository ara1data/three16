---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const isLive = product.status === 'live';
const Tag = product.url ? 'a' : 'div';
---

<Tag
  class:list={[
    'reveal group relative flex flex-col rounded-2xl border p-6 transition-all duration-300',
    isLive
      ? 'border-accent/10 bg-accent/[0.02] hover:border-accent/25 hover:bg-accent/[0.04] hover:-translate-y-1 hover:shadow-[0_8px_40px_-12px_rgba(110,231,183,0.12)]'
      : 'border-border bg-bg-card hover:border-border-hover hover:bg-bg-card-hover hover:-translate-y-0.5',
    product.url && 'cursor-pointer',
  ]}
  {...(product.url ? { href: product.url, target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  <div class="mb-4 flex items-start justify-between gap-3">
    <h3 class="font-heading text-lg font-semibold leading-snug tracking-tight">{product.name}</h3>
    <span
      class:list={[
        'mt-0.5 shrink-0 rounded-full px-2.5 py-0.5 font-mono text-[10px] font-medium uppercase tracking-wider',
        isLive
          ? 'border border-accent/20 text-accent'
          : 'border border-border text-text-muted',
      ]}
    >
      {isLive ? 'Live' : 'Lab'}
    </span>
  </div>

  <p class="mb-5 flex-1 text-sm leading-relaxed text-text-secondary">
    {product.blurb}
  </p>

  {product.tags && product.tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5">
      {product.tags.map((tag) => (
        <span class="rounded-md border border-border bg-bg-elevated px-2 py-0.5 font-mono text-[10px] tracking-wide text-text-muted">
          {tag}
        </span>
      ))}
    </div>
  )}

  {product.url && (
    <div class="mt-5 flex items-center gap-1.5 font-mono text-[10px] font-medium uppercase tracking-wider text-accent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
      Visit
      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
      </svg>
    </div>
  )}
</Tag>
