---
import { products } from '../data/products';
import ProductCard from './ProductCard.astro';

const live = products.filter((p) => p.status === 'live');
const lab = products.filter((p) => p.status === 'lab');
---

<section id="products" class="relative px-6 py-28">
  <div class="mx-auto max-w-[1200px]">
    <div class="reveal mb-16">
      <p class="mb-4 font-mono text-xs font-medium tracking-[0.2em] text-text-muted uppercase">01</p>
      <h2 class="font-heading text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">Products</h2>
      <p class="mt-4 max-w-[480px] text-text-secondary">
        Tools we've shipped and ideas we're actively building.
      </p>
    </div>

    <div class="mb-20">
      <h3 class="mb-8 flex items-center gap-3 font-mono text-xs font-medium tracking-[0.15em] text-accent uppercase">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_8px_rgba(110,231,183,0.5)]"></span>
        Live
      </h3>
      <div class="grid gap-5 sm:grid-cols-2">
        {live.map((product) => <ProductCard product={product} />)}
      </div>
    </div>

    <div>
      <h3 class="mb-8 flex items-center gap-3 font-mono text-xs font-medium tracking-[0.15em] text-text-muted uppercase">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-text-muted"></span>
        In the lab
      </h3>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {lab.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </div>
</section>
